# =============================================================================
# VanguardCMA — secrets
# =============================================================================
# Copy to `secrets.env`, fill in real values, never commit.
# Loaded by scripts/deploy.py and scripts/run_once.py via python-dotenv.
# =============================================================================

# Your Anthropic API key.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Slack bot user OAuth token (xoxb-...).
# Get one at: https://api.slack.com/apps → your app → OAuth & Permissions.
# Scopes required: chat:write, chat:write.public
# See docs/02-create-slack-bot.md for the walkthrough.
SLACK_BOT_TOKEN=xoxb-...
