# =============================================================================
# agent.yaml — CMA-native agent manifest
# =============================================================================
# This file matches the exact shape Anthropic's Managed Agents API accepts
# at POST /v1/agents. You can paste it into the Anthropic console's
# "Create agent" YAML editor, or it can be POSTed by the deploy script.
#
# In a normal deployment, you DO NOT edit this file by hand. It is
# regenerated every time you run `python scripts/deploy.py` from your
# `vanguard.yaml` (which is what you actually edit).
#
# We keep this file under version control as a *.example so you can see
# the materialized shape Vanguard produces — useful for reviewing what's
# about to be deployed, or for hand-creating the agent via the console.
# =============================================================================

name: "Vanguard — Acme Wines"
description: "Competitive intelligence agent for Acme Wines."
model: "claude-opus-4-7"

# The full Vanguard system prompt with competitor list, scoring tuning,
# slack channel, etc. all templated in. Multi-line YAML scalar.
system: |
  # Vanguard — System Prompt

  You are Vanguard, a competitive intelligence agent for Acme Wines.
  ...
  (the deploy script renders the full system prompt here from
  agent/system_prompt.md + vanguard.yaml)
  ...

# No MCP servers — Slack posting is done via bash + curl using a token
# file mounted at /workspace/.slack-token, taught to the agent by the
# `posting-to-slack` skill. Persistence is via Anthropic Memory.
mcp_servers: []

# The CMA built-in agent toolset gives the agent: bash, read, write, edit,
# glob, grep, web_fetch, web_search.
tools:
  - type: agent_toolset_20260401

# Skills attached to the agent. The deploy script populates skill_id and
# version after uploading each SKILL.md directory under ./skills/.
skills:
  - type: custom
    skill_id: "skill_01PROCESSINGSOURCES"
    version: "v..."
  - type: custom
    skill_id: "skill_01SCORINGFINDINGS"
    version: "v..."
  - type: custom
    skill_id: "skill_01FORMATTINGSLACKPOSTS"
    version: "v..."
  - type: custom
    skill_id: "skill_01FORMATTINGRUNLOG"
    version: "v..."
  - type: custom
    skill_id: "skill_01POSTINGTOSLACK"
    version: "v..."
  - type: custom
    skill_id: "skill_01OVERRIDINGSCORING"
    version: "v..."
  - type: custom
    skill_id: "skill_01WRITINGWHYITMATTERS"
    version: "v..."
  - type: custom
    skill_id: "skill_01UNDERSTANDINGACMEWINES"
    version: "v..."
